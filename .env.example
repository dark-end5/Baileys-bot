# .env (copy .env.example -> .env locally and edit)
PAIR_API_URL=http://localhost:4000
USE_MOCK=true

# Admin key for pairing admin endpoints (create codes)
PAIR_ADMIN_KEY=

# Truecaller API (if you have a service)
TRUECALLER_API=https://api.example.com/truecaller
TRUECALLER_KEY=

# Limits
MAX_SEND_BYTES=31457280
